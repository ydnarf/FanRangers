# Build de producción del frontend (Vite, build-time).
# En el despliegue de UN solo servicio, el backend sirve este build, así que la
# API se llama en el MISMO origen con rutas relativas (/api/...). Por eso
# VITE_API_URL se deja vacío.
VITE_API_URL=

# Estas variables se incrustan en el bundle al compilar. Para cambiarlas en
# Render, defínelas en el panel ANTES de hacer el build (o edita este archivo).
VITE_APP_NAME=FanRangers
VITE_HERO_IMAGE=
VITE_KOFI_USERNAME=
VITE_CONTACT_EMAIL=
