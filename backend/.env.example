DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/streaming_platform"
ALLOWED_ORIGIN="https://tu-dominio.com"
PORT=3001
NODE_ENV=production
JWT_SECRET="change-this-to-a-long-random-secret-in-production"
# Set to "true" in production (HTTPS) so the sv_token auth cookie has the Secure flag
COOKIE_SECURE="true"
# Number of reverse proxies in front of the app (0 if none). Needed for correct
# client IP / protocol detection behind a proxy (rate limiting + secure cookies).
TRUST_PROXY=1
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-this-password"
# URL shortener for download links (optional). Supported: tinyurl
SHORTENER_SERVICE=tinyurl
# Leave empty to disable shortening; set to a TinyURL API token to enable
SHORTENER_API_KEY=
