# ─── Backend env vars ────────────────────────────────────────────────────────
# Copia este archivo a `.env` para desarrollo local. NUNCA subas `.env` al repo.
# En Render, estas variables se definen en el panel del servicio (o vía render.yaml).

# Cadena de conexión PostgreSQL (Prisma). En Render se inyecta automáticamente
# desde la base de datos del Blueprint (fromDatabase). Local (Postgres):
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/fanrangers"

# Entorno. Debe ser "production" en Render (activa guardas de seguridad).
NODE_ENV=production

# Puerto. En Render lo provee la plataforma vía process.env.PORT (no lo fijes).
# En local por defecto es 3001.
PORT=3001

# Secreto para firmar los JWT. Mínimo 32 caracteres aleatorios en producción.
# En Render se genera automáticamente (generateValue).
JWT_SECRET="change-this-to-a-long-random-secret-min-32-chars"

# "true" en producción (HTTPS) para que la cookie de sesión sv_token sea Secure.
COOKIE_SECURE="true"

# Nº de proxies inversos delante del servidor. Render = 1.
TRUST_PROXY=1

# Origen permitido para CORS = URL del frontend. En el despliegue de servicio
# único es la propia URL del servicio. Acepta URL completa o host a secas
# (se normaliza a https://). En Render se inyecta vía fromService (host).
ALLOWED_ORIGIN="https://tu-servicio.onrender.com"

# Usuario administrador inicial (lo crea `npm run db:seed`, ejecución manual).
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-this-password"

# Acortador de URLs para enlaces de descarga (opcional). Soportado: tinyurl
SHORTENER_SERVICE=tinyurl
# Vacío = desactiva el acortado. Pon aquí el token de la API de TinyURL para activarlo.
SHORTENER_API_KEY=

# (Opcional) Ruta al build del frontend a servir. Por defecto backend/public.
# FRONTEND_DIST=
